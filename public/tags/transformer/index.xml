<?xml version="1.0" encoding="utf-8" standalone="yes"?><rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom"><channel><title>Transformer on Yifan's Tech Blog</title><link>https://yifan1209.github.io/tags/transformer/</link><description>Recent content in Transformer on Yifan's Tech Blog</description><generator>Hugo -- gohugo.io</generator><language>en-us</language><lastBuildDate>Sat, 14 Sep 2024 00:00:00 +0000</lastBuildDate><atom:link href="https://yifan1209.github.io/tags/transformer/index.xml" rel="self" type="application/rss+xml"/><item><title>ML Basic Knowledge Review</title><link>https://yifan1209.github.io/post/ml-review/</link><pubDate>Sat, 14 Sep 2024 00:00:00 +0000</pubDate><guid>https://yifan1209.github.io/post/ml-review/</guid><description>&lt;h2 id="multi-head-attention-代码"&gt;&lt;a href="#multi-head-attention-%e4%bb%a3%e7%a0%81" class="header-anchor"&gt;&lt;/a&gt;Multi-Head Attention 代码
&lt;/h2&gt;&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-python" data-lang="python"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;import&lt;/span&gt; torch
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;import&lt;/span&gt; torch.nn &lt;span style="color:#66d9ef"&gt;as&lt;/span&gt; nn
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;import&lt;/span&gt; torch.nn.functional &lt;span style="color:#66d9ef"&gt;as&lt;/span&gt; F
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#f92672"&gt;import&lt;/span&gt; math
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#66d9ef"&gt;class&lt;/span&gt; &lt;span style="color:#a6e22e"&gt;MultiHeadAttention&lt;/span&gt;(nn&lt;span style="color:#f92672"&gt;.&lt;/span&gt;Module):
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#66d9ef"&gt;def&lt;/span&gt; &lt;span style="color:#a6e22e"&gt;__init__&lt;/span&gt;(self, d_model, num_heads):
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; super()&lt;span style="color:#f92672"&gt;.&lt;/span&gt;&lt;span style="color:#a6e22e"&gt;__init__&lt;/span&gt;()
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; self&lt;span style="color:#f92672"&gt;.&lt;/span&gt;num_heads &lt;span style="color:#f92672"&gt;=&lt;/span&gt; num_heads
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; self&lt;span style="color:#f92672"&gt;.&lt;/span&gt;d_model &lt;span style="color:#f92672"&gt;=&lt;/span&gt; d_model
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#66d9ef"&gt;assert&lt;/span&gt; d_model &lt;span style="color:#f92672"&gt;%&lt;/span&gt; num_heads &lt;span style="color:#f92672"&gt;==&lt;/span&gt; &lt;span style="color:#ae81ff"&gt;0&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; self&lt;span style="color:#f92672"&gt;.&lt;/span&gt;d_k &lt;span style="color:#f92672"&gt;=&lt;/span&gt; d_model &lt;span style="color:#f92672"&gt;//&lt;/span&gt; num_heads
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; self&lt;span style="color:#f92672"&gt;.&lt;/span&gt;W_q &lt;span style="color:#f92672"&gt;=&lt;/span&gt; nn&lt;span style="color:#f92672"&gt;.&lt;/span&gt;Linear(d_model, d_model)
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; self&lt;span style="color:#f92672"&gt;.&lt;/span&gt;W_k &lt;span style="color:#f92672"&gt;=&lt;/span&gt; nn&lt;span style="color:#f92672"&gt;.&lt;/span&gt;Linear(d_model, d_model)
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; self&lt;span style="color:#f92672"&gt;.&lt;/span&gt;W_v &lt;span style="color:#f92672"&gt;=&lt;/span&gt; nn&lt;span style="color:#f92672"&gt;.&lt;/span&gt;Linear(d_model, d_model)
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; self&lt;span style="color:#f92672"&gt;.&lt;/span&gt;W_o &lt;span style="color:#f92672"&gt;=&lt;/span&gt; nn&lt;span style="color:#f92672"&gt;.&lt;/span&gt;Linear(d_model, d_model)
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#66d9ef"&gt;def&lt;/span&gt; &lt;span style="color:#a6e22e"&gt;scaled_dot_product_attention&lt;/span&gt;(self, Q, K, V, mask&lt;span style="color:#f92672"&gt;=&lt;/span&gt;&lt;span style="color:#66d9ef"&gt;None&lt;/span&gt;):
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; QK &lt;span style="color:#f92672"&gt;=&lt;/span&gt; torch&lt;span style="color:#f92672"&gt;.&lt;/span&gt;matmul(Q, K&lt;span style="color:#f92672"&gt;.&lt;/span&gt;transpose(&lt;span style="color:#f92672"&gt;-&lt;/span&gt;&lt;span style="color:#ae81ff"&gt;2&lt;/span&gt;, &lt;span style="color:#f92672"&gt;-&lt;/span&gt;&lt;span style="color:#ae81ff"&gt;1&lt;/span&gt;)) &lt;span style="color:#f92672"&gt;/&lt;/span&gt; math&lt;span style="color:#f92672"&gt;.&lt;/span&gt;sqrt(self&lt;span style="color:#f92672"&gt;.&lt;/span&gt;d_k)
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#66d9ef"&gt;if&lt;/span&gt; mask &lt;span style="color:#f92672"&gt;is&lt;/span&gt; &lt;span style="color:#f92672"&gt;not&lt;/span&gt; &lt;span style="color:#66d9ef"&gt;None&lt;/span&gt;:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; QK &lt;span style="color:#f92672"&gt;=&lt;/span&gt; QK&lt;span style="color:#f92672"&gt;.&lt;/span&gt;masked_fill(mask &lt;span style="color:#f92672"&gt;==&lt;/span&gt; &lt;span style="color:#ae81ff"&gt;0&lt;/span&gt;, float(&lt;span style="color:#e6db74"&gt;&amp;#39;-inf&amp;#39;&lt;/span&gt;))
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; weights &lt;span style="color:#f92672"&gt;=&lt;/span&gt; F&lt;span style="color:#f92672"&gt;.&lt;/span&gt;softmax(QK, dim&lt;span style="color:#f92672"&gt;=-&lt;/span&gt;&lt;span style="color:#ae81ff"&gt;1&lt;/span&gt;)
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#66d9ef"&gt;return&lt;/span&gt; torch&lt;span style="color:#f92672"&gt;.&lt;/span&gt;matmul(weights, V), weights
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#66d9ef"&gt;def&lt;/span&gt; &lt;span style="color:#a6e22e"&gt;split_heads&lt;/span&gt;(self, x, batch_size):
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#66d9ef"&gt;return&lt;/span&gt; x&lt;span style="color:#f92672"&gt;.&lt;/span&gt;view(batch_size, &lt;span style="color:#f92672"&gt;-&lt;/span&gt;&lt;span style="color:#ae81ff"&gt;1&lt;/span&gt;, self&lt;span style="color:#f92672"&gt;.&lt;/span&gt;num_heads, self&lt;span style="color:#f92672"&gt;.&lt;/span&gt;d_k)&lt;span style="color:#f92672"&gt;.&lt;/span&gt;transpose(&lt;span style="color:#ae81ff"&gt;1&lt;/span&gt;, &lt;span style="color:#ae81ff"&gt;2&lt;/span&gt;)
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#66d9ef"&gt;def&lt;/span&gt; &lt;span style="color:#a6e22e"&gt;forward&lt;/span&gt;(self, q, k, v, mask&lt;span style="color:#f92672"&gt;=&lt;/span&gt;&lt;span style="color:#66d9ef"&gt;None&lt;/span&gt;):
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; batch_size &lt;span style="color:#f92672"&gt;=&lt;/span&gt; q&lt;span style="color:#f92672"&gt;.&lt;/span&gt;size(&lt;span style="color:#ae81ff"&gt;0&lt;/span&gt;)
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; q &lt;span style="color:#f92672"&gt;=&lt;/span&gt; self&lt;span style="color:#f92672"&gt;.&lt;/span&gt;split_heads(self&lt;span style="color:#f92672"&gt;.&lt;/span&gt;W_q(q), batch_size)
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; k &lt;span style="color:#f92672"&gt;=&lt;/span&gt; self&lt;span style="color:#f92672"&gt;.&lt;/span&gt;split_heads(self&lt;span style="color:#f92672"&gt;.&lt;/span&gt;W_k(k), batch_size)
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; v &lt;span style="color:#f92672"&gt;=&lt;/span&gt; self&lt;span style="color:#f92672"&gt;.&lt;/span&gt;split_heads(self&lt;span style="color:#f92672"&gt;.&lt;/span&gt;W_v(v), batch_size)
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; scores, _ &lt;span style="color:#f92672"&gt;=&lt;/span&gt; self&lt;span style="color:#f92672"&gt;.&lt;/span&gt;scaled_dot_product_attention(q, k, v, mask)
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; concat &lt;span style="color:#f92672"&gt;=&lt;/span&gt; scores&lt;span style="color:#f92672"&gt;.&lt;/span&gt;transpose(&lt;span style="color:#ae81ff"&gt;1&lt;/span&gt;,&lt;span style="color:#ae81ff"&gt;2&lt;/span&gt;)&lt;span style="color:#f92672"&gt;.&lt;/span&gt;contiguous()&lt;span style="color:#f92672"&gt;.&lt;/span&gt;view(batch_size, &lt;span style="color:#f92672"&gt;-&lt;/span&gt;&lt;span style="color:#ae81ff"&gt;1&lt;/span&gt;, self&lt;span style="color:#f92672"&gt;.&lt;/span&gt;d_model)
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#66d9ef"&gt;return&lt;/span&gt; self&lt;span style="color:#f92672"&gt;.&lt;/span&gt;W_o(concat)
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;p&gt;面试技巧：一次大矩阵乘法比多次小矩阵乘法快，可以用一个Linear层同时生成Q、K、V：&lt;/p&gt;
&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-python" data-lang="python"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;self&lt;span style="color:#f92672"&gt;.&lt;/span&gt;qkv &lt;span style="color:#f92672"&gt;=&lt;/span&gt; nn&lt;span style="color:#f92672"&gt;.&lt;/span&gt;Linear(d_model, &lt;span style="color:#ae81ff"&gt;3&lt;/span&gt; &lt;span style="color:#f92672"&gt;*&lt;/span&gt; d_model)
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;qkv &lt;span style="color:#f92672"&gt;=&lt;/span&gt; self&lt;span style="color:#f92672"&gt;.&lt;/span&gt;qkv(x)
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;q, k, v &lt;span style="color:#f92672"&gt;=&lt;/span&gt; torch&lt;span style="color:#f92672"&gt;.&lt;/span&gt;split(qkv, d_model, dim&lt;span style="color:#f92672"&gt;=-&lt;/span&gt;&lt;span style="color:#ae81ff"&gt;1&lt;/span&gt;)
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;h2 id="lda-linear-discriminant-analysis"&gt;&lt;a href="#lda-linear-discriminant-analysis" class="header-anchor"&gt;&lt;/a&gt;LDA (Linear Discriminant Analysis)
&lt;/h2&gt;&lt;p&gt;将数据投影到一条线上，选择使类内方差最小、类间方差最大的方向。&lt;/p&gt;
&lt;p&gt;$$J = \frac{w^T S_b w}{w^T S_w w}$$&lt;/p&gt;
&lt;p&gt;&lt;img alt="LDA" class="gallery-image" data-flex-basis="503px" data-flex-grow="209" height="207" loading="lazy" sizes="(max-width: 767px) calc(100vw - 30px), (max-width: 1023px) 700px, (max-width: 1279px) 950px, 1232px" src="https://yifan1209.github.io/post/ml-review/image-20231207183825294.png" width="434"&gt;&lt;/p&gt;
&lt;h2 id="linear-regression"&gt;&lt;a href="#linear-regression" class="header-anchor"&gt;&lt;/a&gt;Linear Regression
&lt;/h2&gt;&lt;p&gt;基本假设：自变量为线性，自变量之间独立，误差独立，误差方差恒定，误差服从正态分布。&lt;/p&gt;
&lt;p&gt;$$w = (X^TX)^{-1}X^Ty$$&lt;/p&gt;
&lt;p&gt;$X^TX$ 不可逆时：&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;用 &lt;strong&gt;SVD&lt;/strong&gt;：$w = V\Sigma^{-1}U^Ty$（即X的伪逆）&lt;/li&gt;
&lt;li&gt;用 &lt;strong&gt;L2正则化&lt;/strong&gt;：$(X^TX + \lambda I)w = X^Ty$&lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;&lt;img alt="SVD" class="gallery-image" data-flex-basis="679px" data-flex-grow="283" height="1045" loading="lazy" sizes="(max-width: 767px) calc(100vw - 30px), (max-width: 1023px) 700px, (max-width: 1279px) 950px, 1232px" src="https://yifan1209.github.io/post/ml-review/cover.png" srcset="https://yifan1209.github.io/post/ml-review/cover_hu_7924634d272df3c8.png 800w, https://yifan1209.github.io/post/ml-review/cover_hu_bb472487e5de7cc8.png 1600w, https://yifan1209.github.io/post/ml-review/cover_hu_948b60f32eadf476.png 2400w, https://yifan1209.github.io/post/ml-review/cover.png 2960w" width="2960"&gt;&lt;/p&gt;
&lt;h2 id="logistic-regression"&gt;&lt;a href="#logistic-regression" class="header-anchor"&gt;&lt;/a&gt;Logistic Regression
&lt;/h2&gt;&lt;p&gt;优化cross entropy等价于优化NLL，两者是从信息论和概率论两个角度看同一个问题。&lt;/p&gt;
&lt;p&gt;&lt;strong&gt;用MSE做Logistic Regression是convex problem吗？&lt;/strong&gt;&lt;/p&gt;
&lt;p&gt;&lt;img alt="logistic regression MSE" class="gallery-image" data-flex-basis="447px" data-flex-grow="186" height="430" loading="lazy" sizes="(max-width: 767px) calc(100vw - 30px), (max-width: 1023px) 700px, (max-width: 1279px) 950px, 1232px" src="https://yifan1209.github.io/post/ml-review/image-20231218154835882.png" srcset="https://yifan1209.github.io/post/ml-review/image-20231218154835882_hu_6ade88fd57b41ac.png 800w, https://yifan1209.github.io/post/ml-review/image-20231218154835882.png 801w" width="801"&gt;&lt;/p&gt;
&lt;h2 id="kmeans"&gt;&lt;a href="#kmeans" class="header-anchor"&gt;&lt;/a&gt;Kmeans
&lt;/h2&gt;&lt;p&gt;缺点：需要人为设定K；对初始值和异常值敏感；假定每类为球形；不能处理离散值。&lt;/p&gt;
&lt;p&gt;选择K值：手肘法&lt;/p&gt;
&lt;h2 id="gmm"&gt;&lt;a href="#gmm" class="header-anchor"&gt;&lt;/a&gt;GMM
&lt;/h2&gt;&lt;p&gt;GMM的EM与Kmeans的区别：&lt;/p&gt;
&lt;ul&gt;
&lt;li&gt;
&lt;p&gt;E步：计算每个点属于每类的&lt;strong&gt;概率&lt;/strong&gt;（软分配），而非直接分类&lt;/p&gt;
&lt;p&gt;&lt;img alt="GMM E step" class="gallery-image" data-flex-basis="1193px" data-flex-grow="497" height="118" loading="lazy" sizes="(max-width: 767px) calc(100vw - 30px), (max-width: 1023px) 700px, (max-width: 1279px) 950px, 1232px" src="https://yifan1209.github.io/post/ml-review/image-20231207052602215.png" width="587"&gt;&lt;/p&gt;
&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;M步：按概率加权计算新的分布参数&lt;/p&gt;
&lt;p&gt;&lt;img alt="GMM M step" class="gallery-image" data-flex-basis="1944px" data-flex-grow="810" height="110" loading="lazy" sizes="(max-width: 767px) calc(100vw - 30px), (max-width: 1023px) 700px, (max-width: 1279px) 950px, 1232px" src="https://yifan1209.github.io/post/ml-review/image-20231207052741751.png" srcset="https://yifan1209.github.io/post/ml-review/image-20231207052741751_hu_eac6b81c4ef5eaa3.png 800w, https://yifan1209.github.io/post/ml-review/image-20231207052741751.png 891w" width="891"&gt;&lt;/p&gt;
&lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;kmeans是硬分配，GMM是软分配；kmeans相当于认为各类分布均为单位方差高斯分布。&lt;/p&gt;
&lt;h2 id="生成模型"&gt;&lt;a href="#%e7%94%9f%e6%88%90%e6%a8%a1%e5%9e%8b" class="header-anchor"&gt;&lt;/a&gt;生成模型
&lt;/h2&gt;&lt;p&gt;GMM、HMM、朴素贝叶斯、贝叶斯网络、GAN、VAE、GPT、DALL-E……&lt;/p&gt;
&lt;p&gt;生成模型学习 $P(x,y)$，判别模型学习 $P(y|x)$。&lt;/p&gt;
&lt;h2 id="ridge--lassol2--l1"&gt;&lt;a href="#ridge--lassol2--l1" class="header-anchor"&gt;&lt;/a&gt;Ridge &amp;amp; Lasso（L2 &amp;amp; L1）
&lt;/h2&gt;&lt;ul&gt;
&lt;li&gt;&lt;strong&gt;L2（Ridge）&lt;/strong&gt;：参数先验为高斯分布&lt;/li&gt;
&lt;li&gt;&lt;strong&gt;L1（Lasso）&lt;/strong&gt;：参数先验为拉普拉斯分布，产生稀疏解&lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;为什么L1稀疏：&lt;/p&gt;
&lt;p&gt;&lt;img alt="L1 sparsity" class="gallery-image" data-flex-basis="698px" data-flex-grow="291" height="388" loading="lazy" sizes="(max-width: 767px) calc(100vw - 30px), (max-width: 1023px) 700px, (max-width: 1279px) 950px, 1232px" src="https://yifan1209.github.io/post/ml-review/image-20231218155615368.png" srcset="https://yifan1209.github.io/post/ml-review/image-20231218155615368_hu_b62a259c082b9e62.png 800w, https://yifan1209.github.io/post/ml-review/image-20231218155615368.png 1130w" width="1130"&gt;&lt;/p&gt;
&lt;h2 id="数据不平衡"&gt;&lt;a href="#%e6%95%b0%e6%8d%ae%e4%b8%8d%e5%b9%b3%e8%a1%a1" class="header-anchor"&gt;&lt;/a&gt;数据不平衡
&lt;/h2&gt;&lt;p&gt;假设正例少、负例多：增大正例采样率、舍弃部分负例、调整阈值、使用XGBoost等集成学习、生成正例、使用precision@k等指标。&lt;/p&gt;
&lt;h2 id="集成学习"&gt;&lt;a href="#%e9%9b%86%e6%88%90%e5%ad%a6%e4%b9%a0" class="header-anchor"&gt;&lt;/a&gt;集成学习
&lt;/h2&gt;&lt;ul&gt;
&lt;li&gt;
&lt;p&gt;&lt;strong&gt;Bagging&lt;/strong&gt;：并行，如Random Forest&lt;/p&gt;
&lt;p&gt;&lt;img alt="bagging" class="gallery-image" data-flex-basis="648px" data-flex-grow="270" height="263" loading="lazy" sizes="(max-width: 767px) calc(100vw - 30px), (max-width: 1023px) 700px, (max-width: 1279px) 950px, 1232px" src="https://yifan1209.github.io/post/ml-review/image-20231207165923309.png" width="711"&gt;&lt;/p&gt;
&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;&lt;strong&gt;Boosting&lt;/strong&gt;：串行，如XGBoost&lt;/p&gt;
&lt;/li&gt;
&lt;/ul&gt;
&lt;h2 id="信息论各种熵"&gt;&lt;a href="#%e4%bf%a1%e6%81%af%e8%ae%ba%e5%90%84%e7%a7%8d%e7%86%b5" class="header-anchor"&gt;&lt;/a&gt;信息论：各种熵
&lt;/h2&gt;&lt;ul&gt;
&lt;li&gt;
&lt;p&gt;&lt;strong&gt;自信息&lt;/strong&gt;：$-\log P(x)$&lt;/p&gt;
&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;&lt;strong&gt;香农熵&lt;/strong&gt;：$H(X) = -\sum P(x)\log P(x)$&lt;/p&gt;
&lt;p&gt;&lt;img alt="entropy" class="gallery-image" data-flex-basis="1208px" data-flex-grow="503" height="229" loading="lazy" sizes="(max-width: 767px) calc(100vw - 30px), (max-width: 1023px) 700px, (max-width: 1279px) 950px, 1232px" src="https://yifan1209.github.io/post/ml-review/image-20231207044108132.png" srcset="https://yifan1209.github.io/post/ml-review/image-20231207044108132_hu_f731b0895c942763.png 800w, https://yifan1209.github.io/post/ml-review/image-20231207044108132.png 1153w" width="1153"&gt;&lt;/p&gt;
&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;&lt;strong&gt;KL散度&lt;/strong&gt;：$D_{KL}(P||Q) = H(P,Q) - H(P)$，衡量两个分布的差异，不对称&lt;/p&gt;
&lt;p&gt;&lt;img alt="KL divergence" class="gallery-image" data-flex-basis="640px" data-flex-grow="266" height="442" loading="lazy" sizes="(max-width: 767px) calc(100vw - 30px), (max-width: 1023px) 700px, (max-width: 1279px) 950px, 1232px" src="https://yifan1209.github.io/post/ml-review/image-20231207044341480.png" srcset="https://yifan1209.github.io/post/ml-review/image-20231207044341480_hu_25cb8525585477c7.png 800w, https://yifan1209.github.io/post/ml-review/image-20231207044341480.png 1179w" width="1179"&gt;&lt;/p&gt;
&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;&lt;strong&gt;交叉熵&lt;/strong&gt;：$H(P,Q) = -\sum P(x)\log Q(x)$&lt;/p&gt;
&lt;p&gt;&lt;img alt="cross entropy" class="gallery-image" data-flex-basis="586px" data-flex-grow="244" height="463" loading="lazy" sizes="(max-width: 767px) calc(100vw - 30px), (max-width: 1023px) 700px, (max-width: 1279px) 950px, 1232px" src="https://yifan1209.github.io/post/ml-review/image-20231207044440926.png" srcset="https://yifan1209.github.io/post/ml-review/image-20231207044440926_hu_5b1cd6f476617189.png 800w, https://yifan1209.github.io/post/ml-review/image-20231207044440926.png 1132w" width="1132"&gt;&lt;/p&gt;
&lt;/li&gt;
&lt;/ul&gt;
&lt;h2 id="评价指标"&gt;&lt;a href="#%e8%af%84%e4%bb%b7%e6%8c%87%e6%a0%87" class="header-anchor"&gt;&lt;/a&gt;评价指标
&lt;/h2&gt;&lt;ul&gt;
&lt;li&gt;
&lt;p&gt;&lt;strong&gt;Precision&lt;/strong&gt;（查准率）：预测为正中真正为正的比例，减少&amp;quot;存伪&amp;quot;错误&lt;/p&gt;
&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;&lt;strong&gt;Recall&lt;/strong&gt;（查全率）：实际为正中被预测为正的比例，减少&amp;quot;去真&amp;quot;错误&lt;/p&gt;
&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;&lt;strong&gt;F1&lt;/strong&gt;：Precision和Recall的调和平均&lt;/p&gt;
&lt;p&gt;&lt;img alt="F1" class="gallery-image" data-flex-basis="850px" data-flex-grow="354" height="103" loading="lazy" sizes="(max-width: 767px) calc(100vw - 30px), (max-width: 1023px) 700px, (max-width: 1279px) 950px, 1232px" src="https://yifan1209.github.io/post/ml-review/image-20231203151426226.png" width="365"&gt;&lt;/p&gt;
&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;&lt;strong&gt;AUC-ROC&lt;/strong&gt;：ROC曲线（TPR vs FPR）下面积&lt;/p&gt;
&lt;/li&gt;
&lt;/ul&gt;
&lt;p&gt;排序指标：MAP、MRR、NDCG&lt;/p&gt;
&lt;h2 id="深度学习训练"&gt;&lt;a href="#%e6%b7%b1%e5%ba%a6%e5%ad%a6%e4%b9%a0%e8%ae%ad%e7%bb%83" class="header-anchor"&gt;&lt;/a&gt;深度学习训练
&lt;/h2&gt;&lt;h3 id="momentum--adam"&gt;&lt;a href="#momentum--adam" class="header-anchor"&gt;&lt;/a&gt;Momentum &amp;amp; Adam
&lt;/h3&gt;&lt;ul&gt;
&lt;li&gt;
&lt;p&gt;&lt;strong&gt;Momentum&lt;/strong&gt;：移动指数加权平均&lt;/p&gt;
&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;&lt;strong&gt;RMSProp&lt;/strong&gt;：梯度按元素平方做指数加权平均，解决不同参数梯度量级差异大的问题&lt;/p&gt;
&lt;/li&gt;
&lt;li&gt;
&lt;p&gt;&lt;strong&gt;Adam&lt;/strong&gt;：Momentum + RMSProp&lt;/p&gt;
&lt;p&gt;&lt;img alt="adam" class="gallery-image" data-flex-basis="265px" data-flex-grow="110" height="739" loading="lazy" sizes="(max-width: 767px) calc(100vw - 30px), (max-width: 1023px) 700px, (max-width: 1279px) 950px, 1232px" src="https://yifan1209.github.io/post/ml-review/image-20231204201808637.png" srcset="https://yifan1209.github.io/post/ml-review/image-20231204201808637_hu_541d9ef88c3dc3bf.png 800w, https://yifan1209.github.io/post/ml-review/image-20231204201808637.png 819w" width="819"&gt;&lt;/p&gt;
&lt;/li&gt;
&lt;/ul&gt;
&lt;h3 id="梯度爆炸消失"&gt;&lt;a href="#%e6%a2%af%e5%ba%a6%e7%88%86%e7%82%b8%e6%b6%88%e5%a4%b1" class="header-anchor"&gt;&lt;/a&gt;梯度爆炸/消失
&lt;/h3&gt;&lt;p&gt;导数 &amp;gt; 1 → 梯度爆炸；导数 &amp;lt; 1 → 梯度消失。&lt;/p&gt;
&lt;p&gt;解决方案：正则化、换激活函数（ReLU）、梯度裁剪、残差连接。&lt;/p&gt;
&lt;p&gt;&lt;strong&gt;BatchNorm&lt;/strong&gt;：&lt;/p&gt;
&lt;p&gt;&lt;img alt="BN" class="gallery-image" data-flex-basis="661px" data-flex-grow="275" height="546" loading="lazy" sizes="(max-width: 767px) calc(100vw - 30px), (max-width: 1023px) 700px, (max-width: 1279px) 950px, 1232px" src="https://yifan1209.github.io/post/ml-review/image-20231207051217778.png" srcset="https://yifan1209.github.io/post/ml-review/image-20231207051217778_hu_645d188819fdc1f4.png 800w, https://yifan1209.github.io/post/ml-review/image-20231207051217778.png 1505w" width="1505"&gt;&lt;/p&gt;
&lt;p&gt;&lt;strong&gt;Residual&lt;/strong&gt;：解决梯度消失/爆炸和退化问题。&lt;/p&gt;
&lt;h3 id="bn-vs-ln"&gt;&lt;a href="#bn-vs-ln" class="header-anchor"&gt;&lt;/a&gt;BN vs LN
&lt;/h3&gt;&lt;p&gt;&lt;strong&gt;BN&lt;/strong&gt;：在batch维度做归一化；batch size小时效果差；推理时用running mean/var。&lt;/p&gt;
&lt;p&gt;&lt;strong&gt;LN&lt;/strong&gt;：在单个样本内做归一化；不依赖batch size；Transformer使用LN的原因：NLP中batch内不同位置的token相关性强，不满足BN的独立同分布假设。&lt;/p&gt;
&lt;p&gt;&lt;img alt="LN vs BN" class="gallery-image" data-flex-basis="939px" data-flex-grow="391" height="184" loading="lazy" sizes="(max-width: 767px) calc(100vw - 30px), (max-width: 1023px) 700px, (max-width: 1279px) 950px, 1232px" src="https://yifan1209.github.io/post/ml-review/v2-3243c53e7d211b4c463b87f9b2f64aa4_720w.webp" width="720"&gt;&lt;/p&gt;
&lt;h2 id="transformer-八股"&gt;&lt;a href="#transformer-%e5%85%ab%e8%82%a1" class="header-anchor"&gt;&lt;/a&gt;Transformer 八股
&lt;/h2&gt;&lt;h3 id="attention"&gt;&lt;a href="#attention" class="header-anchor"&gt;&lt;/a&gt;Attention
&lt;/h3&gt;&lt;p&gt;$$\text{Attention}(Q,K,V) = \text{softmax}\left(\frac{QK^T}{\sqrt{d_k}}\right)V$$&lt;/p&gt;
&lt;p&gt;Scale为什么是 $\sqrt{d_k}$：维度增大时点积方差增大，scale防止softmax进入饱和区导致梯度消失。&lt;/p&gt;
&lt;p&gt;&lt;img alt="attention" class="gallery-image" data-flex-basis="1410px" data-flex-grow="587" height="97" loading="lazy" sizes="(max-width: 767px) calc(100vw - 30px), (max-width: 1023px) 700px, (max-width: 1279px) 950px, 1232px" src="https://yifan1209.github.io/post/ml-review/image-20231217034203052.png" width="570"&gt;&lt;/p&gt;
&lt;h3 id="multi-head-attention"&gt;&lt;a href="#multi-head-attention" class="header-anchor"&gt;&lt;/a&gt;Multi-Head Attention
&lt;/h3&gt;&lt;p&gt;多个头形成多个子空间，让模型关注不同方面的信息，类比CNN中的多个卷积核。&lt;/p&gt;
&lt;h3 id="encoder"&gt;&lt;a href="#encoder" class="header-anchor"&gt;&lt;/a&gt;Encoder
&lt;/h3&gt;&lt;ul&gt;
&lt;li&gt;残差连接：防止退化，灵感来源于LSTM控制门&lt;/li&gt;
&lt;li&gt;Add &amp;amp; Norm：先Add后Norm&lt;/li&gt;
&lt;/ul&gt;
&lt;h3 id="decoder"&gt;&lt;a href="#decoder" class="header-anchor"&gt;&lt;/a&gt;Decoder
&lt;/h3&gt;&lt;ul&gt;
&lt;li&gt;Masked self-attention：mask掉当前位置之后的所有token&lt;/li&gt;
&lt;li&gt;Cross-attention：Q来自decoder，K/V来自encoder输出&lt;/li&gt;
&lt;/ul&gt;
&lt;h3 id="为什么transformer效果好"&gt;&lt;a href="#%e4%b8%ba%e4%bb%80%e4%b9%88transformer%e6%95%88%e6%9e%9c%e5%a5%bd" class="header-anchor"&gt;&lt;/a&gt;为什么Transformer效果好
&lt;/h3&gt;&lt;ol&gt;
&lt;li&gt;能捕捉长距离依赖&lt;/li&gt;
&lt;li&gt;并行计算，比RNN快&lt;/li&gt;
&lt;li&gt;网络可以做更深&lt;/li&gt;
&lt;/ol&gt;
&lt;h2 id="bert"&gt;&lt;a href="#bert" class="header-anchor"&gt;&lt;/a&gt;BERT
&lt;/h2&gt;&lt;h3 id="byte-pair-encoding-bpe"&gt;&lt;a href="#byte-pair-encoding-bpe" class="header-anchor"&gt;&lt;/a&gt;Byte Pair Encoding (BPE)
&lt;/h3&gt;&lt;p&gt;迭代合并最高频的字符对；词表大小先增后减，需要取中间值。&lt;/p&gt;
&lt;p&gt;&lt;img alt="BPE" class="gallery-image" data-flex-basis="419px" data-flex-grow="174" height="470" loading="lazy" sizes="(max-width: 767px) calc(100vw - 30px), (max-width: 1023px) 700px, (max-width: 1279px) 950px, 1232px" src="https://yifan1209.github.io/post/ml-review/image-20231217184751754.png" srcset="https://yifan1209.github.io/post/ml-review/image-20231217184751754_hu_e79bf89bfea0cb5.png 800w, https://yifan1209.github.io/post/ml-review/image-20231217184751754.png 822w" width="822"&gt;&lt;/p&gt;
&lt;h2 id="快速排序"&gt;&lt;a href="#%e5%bf%ab%e9%80%9f%e6%8e%92%e5%ba%8f" class="header-anchor"&gt;&lt;/a&gt;快速排序
&lt;/h2&gt;&lt;div class="highlight"&gt;&lt;pre tabindex="0" style="color:#f8f8f2;background-color:#272822;-moz-tab-size:4;-o-tab-size:4;tab-size:4;-webkit-text-size-adjust:none;"&gt;&lt;code class="language-python" data-lang="python"&gt;&lt;span style="display:flex;"&gt;&lt;span&gt;&lt;span style="color:#66d9ef"&gt;def&lt;/span&gt; &lt;span style="color:#a6e22e"&gt;quick_sort&lt;/span&gt;(lst, i, j):
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#66d9ef"&gt;if&lt;/span&gt; i &lt;span style="color:#f92672"&gt;&amp;gt;=&lt;/span&gt; j:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#66d9ef"&gt;return&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; pivot, lo, hi &lt;span style="color:#f92672"&gt;=&lt;/span&gt; lst[i], i, j
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#66d9ef"&gt;while&lt;/span&gt; i &lt;span style="color:#f92672"&gt;&amp;lt;&lt;/span&gt; j:
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#66d9ef"&gt;while&lt;/span&gt; i &lt;span style="color:#f92672"&gt;&amp;lt;&lt;/span&gt; j &lt;span style="color:#f92672"&gt;and&lt;/span&gt; lst[j] &lt;span style="color:#f92672"&gt;&amp;gt;=&lt;/span&gt; pivot: j &lt;span style="color:#f92672"&gt;-=&lt;/span&gt; &lt;span style="color:#ae81ff"&gt;1&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; lst[i] &lt;span style="color:#f92672"&gt;=&lt;/span&gt; lst[j]
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; &lt;span style="color:#66d9ef"&gt;while&lt;/span&gt; i &lt;span style="color:#f92672"&gt;&amp;lt;&lt;/span&gt; j &lt;span style="color:#f92672"&gt;and&lt;/span&gt; lst[i] &lt;span style="color:#f92672"&gt;&amp;lt;=&lt;/span&gt; pivot: i &lt;span style="color:#f92672"&gt;+=&lt;/span&gt; &lt;span style="color:#ae81ff"&gt;1&lt;/span&gt;
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; lst[j] &lt;span style="color:#f92672"&gt;=&lt;/span&gt; lst[i]
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; lst[j] &lt;span style="color:#f92672"&gt;=&lt;/span&gt; pivot
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; quick_sort(lst, lo, i&lt;span style="color:#f92672"&gt;-&lt;/span&gt;&lt;span style="color:#ae81ff"&gt;1&lt;/span&gt;)
&lt;/span&gt;&lt;/span&gt;&lt;span style="display:flex;"&gt;&lt;span&gt; quick_sort(lst, i&lt;span style="color:#f92672"&gt;+&lt;/span&gt;&lt;span style="color:#ae81ff"&gt;1&lt;/span&gt;, hi)
&lt;/span&gt;&lt;/span&gt;&lt;/code&gt;&lt;/pre&gt;&lt;/div&gt;&lt;p&gt;为什么快排比堆排快：cache locality。快排访问连续内存，cache命中率高；堆排需要比较数组前后两半，cache miss频繁。&lt;/p&gt;</description></item></channel></rss>